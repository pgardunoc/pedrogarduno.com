---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
}

const { title, description, ogType = 'website', pubDate } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/assets/img/og-image.png', Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:type" content={ogType}>
  <meta property="og:site_name" content="Pedro Garduno">
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()}>}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@pgardunoc">
  <meta name="twitter:creator" content="@pgardunoc">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/assets/img/favicon.png" type="image/png">
  <link href="/assets/img/apple-touch-icon.png" rel="apple-touch-icon">
  <link rel="alternate" type="application/rss+xml" title="Pedro Garduno — Blog" href="/rss.xml">
  <link rel="preload" href="/assets/fonts/geist-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/geist-mono-latin.woff2" as="font" type="font/woff2" crossorigin>

  <slot name="head" />

  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TF8428JCHL"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-TF8428JCHL');
  </script>
</head>
<body>

<div class="wrap">

  <!-- nav -->
  <div class="nav">
    <a class="nav-logo" href="/">pedrogarduno<span>.com</span></a>
    <div class="nav-links">
      <a class="nav-link" href="/blog">Blog</a>
      <a class="nav-link" rel="me" href="https://github.com/pgardunoc">GitHub</a>
      <a class="nav-link" rel="me" href="https://x.com/pgardunoc">X</a>
      <a class="nav-link" rel="me" href="https://www.linkedin.com/in/pgarduno/">LinkedIn</a>
      <a class="btn-contact" href="mailto:pgardunoc@gmail.com">Get in touch</a>
    </div>
  </div>

  <slot />

  <!-- footer -->
  <div class="footer">
    <div>
      <div class="footer-cta">Let's talk.</div>
      <a class="footer-email" href="mailto:pgardunoc@gmail.com">pgardunoc@gmail.com</a>
    </div>
    <div class="footer-links">
      <a class="nav-link" href="/blog">Blog</a>
      <a class="nav-link" rel="me" href="https://github.com/pgardunoc">GitHub</a>
      <a class="nav-link" rel="me" href="https://x.com/pgardunoc">X</a>
      <a class="nav-link" rel="me" href="https://stackoverflow.com/users/1492159/pgardunoc">Stack Overflow</a>
      <a class="nav-link" rel="me" href="https://www.linkedin.com/in/pgarduno/">LinkedIn</a>
      <a class="nav-link" href="/assets/Resume-PedroGarduno.pdf" download>Resume (PDF)</a>
    </div>
  </div>

</div>

</body>
</html>

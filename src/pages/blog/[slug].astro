---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // Drafts render in `npm run dev` for previewing, but are excluded from builds.
  const posts = await getCollection('blog', ({ data }) => (import.meta.env.PROD ? !data.draft : true));
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base
  title={`${post.data.title} — Pedro Garduno`}
  description={post.data.description}
  ogType="article"
  pubDate={post.data.pubDate}
>
  <article class="post">
    <header>
      <div class="post-kicker">
        <a href="/blog">← Blog</a> · <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
      </div>
      <h1>{post.data.title}</h1>
      <p class="post-lede">{post.data.description}</p>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style is:global>
  .post { padding: 72px 64px 80px; max-width: 780px; }
  .post-kicker { font: 500 12px 'Geist Mono', monospace; letter-spacing: .08em; color: #8a8a93; margin-bottom: 22px; }
  .post-kicker a { color: var(--accent); }
  .post h1 { margin: 0 0 16px; font: 600 40px/1.15 'Geist', sans-serif; letter-spacing: -0.03em; color: #fafafa; }
  .post-lede { margin: 0 0 40px; font: 400 18px/1.6 'Geist', sans-serif; color: #a8a8b0; }

  .prose { font: 400 16px/1.75 'Geist', sans-serif; color: #c6c6cc; }
  .prose h2 { margin: 44px 0 16px; font: 600 24px/1.3 'Geist', sans-serif; letter-spacing: -0.02em; color: #fafafa; }
  .prose h3 { margin: 32px 0 12px; font: 600 19px/1.3 'Geist', sans-serif; color: #fafafa; }
  .prose p { margin: 0 0 20px; }
  .prose a { color: var(--accent); border-bottom: 1px solid var(--accent-border); }
  .prose strong { color: #ececee; }
  .prose ul, .prose ol { margin: 0 0 20px; padding-left: 24px; }
  .prose li { margin-bottom: 8px; }
  .prose blockquote { margin: 0 0 20px; padding: 4px 0 4px 20px; border-left: 2px solid var(--accent); color: #a8a8b0; }
  .prose blockquote p:last-child { margin-bottom: 0; }
  .prose code { font: 400 14px 'Geist Mono', monospace; background: #1a1a1d; border: 1px solid rgba(255,255,255,.08); border-radius: 4px; padding: 2px 6px; }
  .prose pre { margin: 0 0 20px; padding: 18px 20px; background: #111113; border: 1px solid rgba(255,255,255,.08); border-radius: 10px; overflow-x: auto; }
  .prose pre code { background: none; border: none; padding: 0; font-size: 13.5px; line-height: 1.6; }
  .prose img { max-width: 100%; border-radius: 10px; }
  .prose hr { margin: 36px 0; border: none; border-top: 1px solid rgba(255,255,255,.07); }

  @media (max-width: 820px) {
    .post { padding: 44px 24px 56px; }
    .post h1 { font-size: 30px; }
  }
</style>
